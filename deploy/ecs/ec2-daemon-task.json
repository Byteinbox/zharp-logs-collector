{
  "_comment": "Zharp Collector — ECS EC2 daemon task definition",
  "_usage": [
    "1. Store your API key in AWS Secrets Manager:",
    "   aws secretsmanager create-secret --name zharp/api-key --secret-string 'your_api_key'",
    "",
    "2. Register this task definition:",
    "   aws ecs register-task-definition --cli-input-json file://ec2-daemon-task.json",
    "",
    "3. Create a daemon service (one container per EC2 instance):",
    "   aws ecs create-service \\",
    "     --cluster YOUR_CLUSTER \\",
    "     --service-name zharp-collector \\",
    "     --task-definition zharp-collector \\",
    "     --scheduling-strategy DAEMON",
    "",
    "The collector will automatically tail logs from all containers on each EC2 instance."
  ],
  "family": "zharp-collector",
  "networkMode": "host",
  "requiresCompatibilities": ["EC2"],
  "containerDefinitions": [
    {
      "name": "zharp-collector",
      "image": "ghcr.io/byteinbox/zharp-logs-collector:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 4317, "hostPort": 4317, "protocol": "tcp" },
        { "containerPort": 4318, "hostPort": 4318, "protocol": "tcp" },
        { "containerPort": 13133, "hostPort": 13133, "protocol": "tcp" }
      ],
      "secrets": [
        {
          "name": "ZHARP_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:zharp/api-key"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "docker-containers",
          "containerPath": "/var/lib/docker/containers",
          "readOnly": true
        },
        {
          "sourceVolume": "docker-sock",
          "containerPath": "/var/run/docker.sock",
          "readOnly": false
        },
        {
          "sourceVolume": "hostfs",
          "containerPath": "/hostfs",
          "readOnly": true
        },
        {
          "sourceVolume": "collector-config",
          "containerPath": "/etc/zharp-collector",
          "readOnly": true
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:13133 || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/zharp-collector",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "collector",
          "awslogs-create-group": "true"
        }
      },
      "resourceRequirements": [],
      "cpu": 256,
      "memory": 256,
      "memoryReservation": 128
    }
  ],
  "volumes": [
    {
      "name": "docker-containers",
      "host": { "sourcePath": "/var/lib/docker/containers" }
    },
    {
      "name": "docker-sock",
      "host": { "sourcePath": "/var/run/docker.sock" }
    },
    {
      "name": "hostfs",
      "host": { "sourcePath": "/" }
    },
    {
      "name": "collector-config",
      "host": { "sourcePath": "/etc/zharp-collector" }
    }
  ]
}
